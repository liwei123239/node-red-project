{
  "name": "node-red-project",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @node-red-project/db db:push",
    "db:studio": "turbo -F @node-red-project/db db:studio",
    "db:generate": "turbo -F @node-red-project/db db:generate",
    "db:migrate": "turbo -F @node-red-project/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@node-red-project/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@node-red-project/config": "workspace:*",
    "@types/node": "catalog:",
    "husky": "latest",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "pnpm@10.32.1"
}
