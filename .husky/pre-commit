# ultracite
#!/bin/sh
# Check if there are any staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

# Run formatter on staged files only (NUL-delimited + `--` to safely handle special/leading-hyphen filenames)
FORMAT_EXIT_CODE=0
git diff --cached --name-only --diff-filter=ACMR -z | xargs -0 pnpm dlx ultracite fix -- || FORMAT_EXIT_CODE=$?

# Re-stage the (possibly reformatted) staged files
git diff --cached --name-only --diff-filter=ACMR -z | xargs -0 -I {} sh -c '[ -f "$1" ] && git add -- "$1"' _ {}

if [ $FORMAT_EXIT_CODE -ne 0 ]; then
  echo "Ultracite found issues that could not be auto-fixed."
  exit $FORMAT_EXIT_CODE
fi

echo "✨ Files formatted by Ultracite"
# ultracite end
